# Slack app credentials. Never commit real values.
SLACK_BOT_TOKEN=placeholder-slack-bot-token
SLACK_APP_TOKEN=placeholder-slack-app-token
SLACK_ALLOWED_TEAM_ID=T_PLACEHOLDER
SLACK_ALLOWED_USER_IDS=U_PLACEHOLDER

# Host identity shown by /codex-ping.
BOT_HOSTNAME=dev-host

# Codex execution limits.
CODEX_CLI_PATH=codex
MAX_SESSION_TIMEOUT_SECS=600
CODEX_OUTPUT_MAX_CHARS=39000

# Variables allowed to reach the child Codex process.
CODEX_CHILD_ENV_ALLOWLIST=HOME,PATH,USER,SHELL,CODEX_HOME,CODEX_PROFILE_ROOT,CODEX_ALLOWED_WORKSPACES

# Host-local paths. Use placeholders here; keep real paths in an untracked .env.
CODEX_PROFILE_ROOT=/path/to/codex-profile
CODEX_DEFAULT_WORKSPACE=/path/to/workspace-a
CODEX_ALLOWED_WORKSPACES=/path/to/workspace-a;/path/to/workspace-b
# Optional host-local alias catalog. If unset, the app looks for workspaces.json next to the binary.
# CODEX_WORKSPACE_CATALOG_PATH=./workspaces.json
QUEUE_DB_PATH=./data/sessions.db

RUST_LOG=info
